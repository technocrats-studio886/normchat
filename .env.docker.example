APP_NAME=Normchat
APP_ENV=local
APP_KEY=base64:dkeE9+qv1jWq+2u6qaq8Bf0Roc6+8ckfH5zqsr2+fA0=
APP_DEBUG=true
APP_URL=http://localhost:8000
MARKETING_URL=https://sysnavia.com/normchat
NORMCHAT_APP_URL=https://normchat.sysnavia.com
NORMCHAT_MARKETING_PATH=/normchat

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=normchat
DB_USERNAME=normchat
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=normchat_attachments
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=default

NORMCHAT_STORAGE_ROOT=/opt/normchat/storage

REVERB_APP_ID=normchat
REVERB_APP_KEY=normchat-key
REVERB_APP_SECRET=normchat-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY=${REVERB_APP_KEY}
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=18080
VITE_REVERB_SCHEME=http

INTERDOTZ_CLIENT_ID=
INTERDOTZ_CLIENT_SECRET=
INTERDOTZ_API_BASE=https://api-interdotz.technocrats.studio
INTERDOTZ_SSO_BASE=https://interdotz.technocrats.studio
INTERDOTZ_REDIRECT_URI=${APP_URL}/sso/interdotz/callback

# ── AI Provider Connect ──────────────────────────────────────
# ChatGPT & Claude: users enter API key at login (no OAuth)
OPENAI_CHAT_MODEL=gpt-4o-mini
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514
GEMINI_CHAT_MODEL=gemini-2.0-flash

# Gemini / Google OAuth (falls back to GOOGLE_CLIENT_*)
GEMINI_CLIENT_ID=
GEMINI_CLIENT_SECRET=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
