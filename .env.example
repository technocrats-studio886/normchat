APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
MARKETING_URL=http://localhost
NORMCHAT_APP_URL=http://localhost
NORMCHAT_MARKETING_PATH=/normchat

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=normchat
DB_USERNAME=normchat
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=normchat_attachments
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=default

NORMCHAT_STORAGE_ROOT=/opt/normchat/storage

REVERB_APP_ID=normchat
REVERB_APP_KEY=normchat-key
REVERB_APP_SECRET=normchat-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

INTERDOTZ_CLIENT_ID=
INTERDOTZ_CLIENT_SECRET=
INTERDOTZ_API_BASE=https://api-interdotz.technocrats.studio
INTERDOTZ_SSO_BASE=https://interdotz.technocrats.studio
INTERDOTZ_REDIRECT_URI="${APP_URL}/sso/interdotz/callback"

# ── AI Provider Connect ──────────────────────────────────────
# ChatGPT & Claude: users enter their own API key (no OAuth needed)
# AI chat models (used by ProcessGroupChatQueueJob)
OPENAI_CHAT_MODEL=gpt-4o-mini
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514
GEMINI_CHAT_MODEL=gemini-2.0-flash

# Gemini / Google OAuth (falls back to GOOGLE_CLIENT_* if not set)
GEMINI_CLIENT_ID=
GEMINI_CLIENT_SECRET=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
